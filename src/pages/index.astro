---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate, visibleNotes } from "../lib/notes";

const latestNote = visibleNotes(await getCollection("notes"))[0];
---

<BaseLayout>
  <section class="about-hero section-shell">
    <h1>Hi, I’m Imran.</h1>
    <p>
      I’m interested in deep learning and understanding how neural networks learn algorithms that generalize.
    </p>
    <dl class="about-facts">
      <div>
        <dt>Based in</dt>
        <dd>Hamburg, Germany</dd>
      </div>
      <div>
        <dt>Education</dt>
        <dd>
          <span>M.Sc. Intelligent Adaptive Systems, University of Hamburg</span>
          <span>B.Sc. Computer Science, University of Strasbourg</span>
        </dd>
      </div>
      <div>
        <dt>Industry experience</dt>
        <dd>Research and development, data and ML engineering, MLOps</dd>
      </div>
      <div>
        <dt>Interests</dt>
        <dd>
          <ul class="interest-list">
            <li>Expressivity, compositionality, and systematic generalization</li>
            <li>Learning soft algorithms with neural networks</li>
            <li>Looping (depth-recurrent) transformers</li>
            <li>Mechanistic interpretability</li>
          </ul>
        </dd>
      </div>
    </dl>
    <nav class="profile-links" aria-label="Profile links">
      <a href="https://github.com/iibrahimli">GitHub ↗</a>
      <a href="https://scholar.google.com/citations?user=Hl0FjYgAAAAJ&hl=en">Google Scholar ↗</a>
      <a href="https://www.linkedin.com/in/iibrahimli/">LinkedIn ↗</a>
      <a href="/files/cv.pdf" target="_blank" rel="noopener">CV ↗</a>
    </nav>
  </section>

  {latestNote && (
    <section class="latest-note section-shell" aria-labelledby="latest-note-heading">
      <div class="latest-note-label">
        <span>Latest note</span>
        <a href="/notes/">All notes →</a>
      </div>
      <a class="latest-note-link" href={`/notes/${latestNote.id}/`}>
        <div>
          <h2 id="latest-note-heading">{latestNote.data.title}</h2>
          <p>{latestNote.data.description}</p>
        </div>
        <time datetime={latestNote.data.published.toISOString()}>
          {formatDate(latestNote.data.published)}
        </time>
      </a>
    </section>
  )}
</BaseLayout>
