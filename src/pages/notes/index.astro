---
import { getCollection } from "astro:content";
import NoteList from "../../components/NoteList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { visibleNotes } from "../../lib/notes";

const notes = visibleNotes(await getCollection("notes"));
---

<BaseLayout
  title="Notes"
  description="Notes by Imran Ibrahimli on deep learning, research, and related ideas."
>
  <section class="notes-page section-shell">
    <header class="notes-intro">
      <h1>Notes</h1>
      <p>Research observations, conference notes, and things I want to understand better.</p>
    </header>
    <NoteList notes={notes} />
  </section>
</BaseLayout>
