---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import NoteList from "../../components/NoteList.astro";
import { visibleNotes } from "../../lib/notes";

const notes = visibleNotes(await getCollection("notes"));
---

<BaseLayout
  title="Research notes"
  description="Deep-learning research notes, compact experiments, and explanations by Imran Ibrahimli."
>
  <section class="page-intro section-shell">
    <p class="eyebrow">The notebook</p>
    <h1>Research notes</h1>
    <p>
      Experiments and explanations about deep learning, with code, assumptions,
      and uncertainty left visible.
    </p>
  </section>
  <section class="archive section-shell" aria-label="All research notes">
    <NoteList notes={notes} />
  </section>
</BaseLayout>
